{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/auth/(.*)",
      "destination": "https://employee-enrolment-production.up.railway.app/auth/$1"
    },
    {
      "source": "/employees/(.*)",
      "destination": "https://employee-enrolment-production.up.railway.app/employees/$1"
    },
    {
      "source": "/",
      "destination": "/src/main/resources/static/index.html"
    },
    {
      "source": "/admin-dashboard",
      "destination": "/src/main/resources/static/admin-dashboard.html"
    },
    {
      "source": "/employee-dashboard",
      "destination": "/src/main/resources/static/employee-dashboard.html"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/src/main/resources/static/assets/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
