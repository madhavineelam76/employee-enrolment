{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/auth/(.*)",
      "destination": "https://employee-enrolment-production.up.railway.app/auth/$1"
    },
    {
      "source": "/employees/(.*)",
      "destination": "https://employee-enrolment-production.up.railway.app/employees/$1"
    }
  ],
  "routes": [
    {
      "src": "/admin-dashboard",
      "dest": "/admin-dashboard.html"
    },
    {
      "src": "/employee-dashboard",
      "dest": "/employee-dashboard.html"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
