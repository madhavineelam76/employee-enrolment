{
  "version": 2,
  "routes": [
    {
      "src": "/auth/(.*)",
      "dest": "https://employee-enrolment-production.up.railway.app/auth/$1"
    },
    {
      "src": "/employees/(.*)",
      "dest": "https://employee-enrolment-production.up.railway.app/employees/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/admin-dashboard",
      "dest": "/admin-dashboard"
    },
    {
      "src": "/employee-dashboard",
      "dest": "/employee-dashboard"
    }
  ]
}
